# --- Gemini (server-side only, never expose to the browser) ---
# One key, or several for quota rotation. GEMINI_API_KEYS (comma-separated) wins,
# then GEMINI_API_KEY / GEMINI_API_KEY_2 / GEMINI_API_KEY_3 / GOOGLE_API_KEY.
GEMINI_API_KEY=
GEMINI_API_KEYS=

# --- Supabase JWT verification ---
# The backend verifies the Supabase access token on every /api call.
# Project Settings -> API -> JWT Secret (HS256). Required in production.
SUPABASE_JWT_SECRET=
# Optional: set to skip JWT verification for local dev only. NEVER set in prod.
DEV_ALLOW_NO_AUTH=

# --- Supabase project (public values) — backend forwards the user token to the
# quota RPC. If unset, per-user quota enforcement is skipped (dev only). ---
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- Per-user daily quota (AI extract calls) ---
DAILY_EXTRACT_LIMIT=50

# --- Upload guardrails (large images auto-downscaled; PDFs processed in page batches) ---
MAX_UPLOAD_MB=50
MAX_PDF_PAGES=300
MAX_IMAGE_DIM=2000
PDF_BATCH_PAGES=8
